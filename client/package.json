{
  "name": "fetch-client",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "bootstrap": "^4.0.0-beta.2",
    "classnames": "^2.2.5",
    "enzyme-adapter-react-16": "^1.1.0",
    "googleapis": "^23.0.0",
    "jest-enzyme": "^4.0.1",
    "lint-staged": "^6.0.0",
    "node-sass-chokidar": "0.0.3",
    "npm-run-all": "^4.1.2",
    "prettier": "^1.9.2",
    "prop-types": "^15.6.0",
    "react": "^16.6.0",
    "react-addons-css-transition-group": "^15.6.2",
    "react-big-calendar": "^0.17.0",
    "react-dom": "^16.6.0",
    "react-facebook-login": "^3.7.2",
    "react-google-button": "^0.4.0",
    "react-infinite-calendar": "^2.3.1",
    "react-router-dom": "^4.2.2",
    "react-scripts": "^2.0.5",
    "react-simple-line-icons": "^1.0.8",
    "react-social-login": "^3.4.2",
    "react-spinners": "^0.2.5",
    "react-test-renderer": "^16.6.0",
    "react-transition-group": "^2.2.1",
    "reactstrap": "^5.0.0-alpha.4",
    "whatwg-fetch": "^2.0.3"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,json,css}": [
      "prettier --single-quote --write",
      "git add"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "src/**/*.spec.{js,jsx}",
      "components/**/*.{js,jsx}",
      "components/**/*.spec.{js,jsx}",
      "!components/**/*.stories.jsx",
      "!components/**/index.js",
      "!src/**/*.stories.jsx",
      "!src/**/index.js",
      "!node_modules/",
      "!src/components/BgCalendar/*.{js,jsx}",
      "!src/registerServiceWorker.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  },
  "scripts": {
    "build-css": "node-sass-chokidar src/ -o src/",
    "coverage": "open ./coverage/lcov-report/index.html",
    "watch-css": "npm run build-css && node-sass-chokidar src/ -o src/ --watch --recursive",
    "start-js": "react-scripts start",
    "start": "npm-run-all -p watch-css start-js",
    "build-js": "react-scripts build",
    "build": "node scripts/build.js",
    "test": "react-scripts test --env=jsdom --coverage --colors",
    "eject": "react-scripts eject",
    "storybook": "start-storybook -p 9009 -s public",
    "build-storybook": "build-storybook -s public",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand --debug"
  },
  "proxy": "http://localhost:8000",
  "devDependencies": {
    "@sambego/storybook-styles": "^1.0.0",
    "@storybook/addon-actions": "^3.2.17",
    "@storybook/addon-info": "^3.2.17",
    "@storybook/addon-knobs": "^3.2.17",
    "@storybook/addon-links": "^3.2.16",
    "@storybook/addon-storyshots": "^3.2.17",
    "@storybook/react": "^3.4.11",
    "babel-eslint": "9.0.0",
    "babel-plugin-transform-class-properties": "^6.24.1",
    "babel-preset-env": "^1.7.0",
    "enzyme": "^3.7.0",
    "enzyme-adapter-react-16": "^1.1.0",
    "storybook-addon-specifications": "^2.1.1"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
